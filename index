<script>
  window._contas = [];
  let tabAtual = 'dashboard';
  let charts   = {};

  function fmt(v) { return 'R$ ' + Number(v).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}); }
  function fmtData(d) { return d ? d.split('-').reverse().join('/') : '—'; }
  function showLoader(on) { document.getElementById('loaderBar').style.display = on ? 'block' : 'none'; }
  function showToast(msg, isError=false) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast' + (isError?' error':'') + ' show';
    setTimeout(()=>t.className='toast', 2800);
  }

  function filtradas() {
    const di=document.getElementById('dtInicio').value, df=document.getElementById('dtFim').value, st=document.getElementById('filtroStatus').value;
    return window._contas.filter(c=>{
      if(di && c.venc<di) return false;
      if(df && c.venc>df) return false;
      if(st && c.status!==st) return false;
      return true;
    });
  }

  function setTab(tab) {
    tabAtual=tab;
    document.querySelectorAll('.nav-item').forEach((t,i)=>t.classList.toggle('active',['dashboard','pagar','receber'][i]===tab));
    ['dashboard','pagar','receber'].forEach(v=>{ document.getElementById('view-'+v).style.display=v===tab?'':'none'; });
    const titles={dashboard:['Dashboard','Visão geral das finanças'],pagar:['Contas a Pagar','Gerencie suas obrigações'],receber:['Contas a Receber','Acompanhe seus créditos']};
    document.getElementById('pageTitle').textContent=titles[tab][0];
    document.getElementById('pageSub').textContent=titles[tab][1];
    renderAll();
  }

  function renderAll() { if(tabAtual==='dashboard') renderDashboard(); else renderTabela(tabAtual); }

  function renderDashboard() {
    const f=filtradas(), pagar=f.filter(c=>c.tipo==='pagar'), receber=f.filter(c=>c.tipo==='receber');
    const totalPagar=pagar.reduce((s,c)=>s+Number(c.valor),0), totalReceber=receber.reduce((s,c)=>s+Number(c.valor),0);
    const saldo=totalReceber-totalPagar, vencidos=f.filter(c=>c.status==='Vencido').reduce((s,c)=>s+Number(c.valor),0);
    const pendentes=f.filter(c=>c.status==='Pendente').length, pagos=f.filter(c=>c.status==='Pago').length;
    document.getElementById('metrics').innerHTML=`
      <div class="metric"><div class="metric-label">Total a Receber</div><div class="metric-value green">${fmt(totalReceber)}</div><div class="metric-delta">${receber.length} lançamento(s)</div></div>
      <div class="metric"><div class="metric-label">Total a Pagar</div><div class="metric-value red">${fmt(totalPagar)}</div><div class="metric-delta">${pagar.length} lançamento(s)</div></div>
      <div class="metric"><div class="metric-label">Saldo do Período</div><div class="metric-value ${saldo>=0?'blue':'red'}">${fmt(saldo)}</div><div class="metric-delta">${saldo>=0?'Superávit':'Déficit'}</div></div>
      <div class="metric"><div class="metric-label">Total Vencido</div><div class="metric-value red">${fmt(vencidos)}</div><div class="metric-delta">${f.filter(c=>c.status==='Vencido').length} item(s)</div></div>
      <div class="metric"><div class="metric-label">Pendentes</div><div class="metric-value">${pendentes}</div><div class="metric-delta">aguardando</div></div>
      <div class="metric"><div class="metric-label">Liquidados</div><div class="metric-value green">${pagos}</div><div class="metric-delta">concluídos</div></div>`;
    renderCharts(f);
  }

  function renderCharts(f) {
    const meses=['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
    const rec=new Array(12).fill(0), pag=new Array(12).fill(0);
    f.forEach(c=>{ const m=parseInt(c.venc.split('-')[1])-1; if(c.tipo==='receber') rec[m]+=Number(c.valor); else pag[m]+=Number(c.valor); });
    let acum=0;
    const saldoAcum=Array.from({length:12},(_,i)=>{ acum+=rec[i]-pag[i]; return Math.round(acum); });
    if(charts.fluxo) charts.fluxo.destroy();
    charts.fluxo=new Chart(document.getElementById('chartFluxo'),{type:'bar',data:{labels:meses,datasets:[{label:'Receitas',data:rec.map(v=>Math.round(v)),backgroundColor:'#5DCAA5',borderRadius:4},{label:'Despesas',data:pag.map(v=>Math.round(v)),backgroundColor:'#F09595',borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{font:{size:11},color:'#888'},grid:{display:false}},y:{ticks:{callback:v=>'R$'+Math.round(v/1000)+'k',font:{size:11},color:'#888'},grid:{color:'rgba(128,128,128,0.1)'}}}}});
    const cats={}, statusCount={};
    f.forEach(c=>{ cats[c.cat]=(cats[c.cat]||0)+Number(c.valor); });
    f.forEach(c=>{ statusCount[c.status]=(statusCount[c.status]||0)+1; });
    if(charts.cat) charts.cat.destroy();
    charts.cat=new Chart(document.getElementById('chartCategoria'),{type:'doughnut',data:{labels:Object.keys(cats),datasets:[{data:Object.values(cats).map(v=>Math.round(v)),backgroundColor:['#378ADD','#1D9E75','#D85A30','#D4537E','#BA7517','#888780','#534AB7'],borderWidth:2,borderColor:'transparent'}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{font:{size:11},boxWidth:10,padding:8}}}}});
    const stColors={'Pago':'#5DCAA5','Pendente':'#EF9F27','Vencido':'#E24B4A'};
    if(charts.status) charts.status.destroy();
    charts.status=new Chart(document.getElementById('chartStatus'),{type:'pie',data:{labels:Object.keys(statusCount),datasets:[{data:Object.values(statusCount),backgroundColor:Object.keys(statusCount).map(s=>stColors[s]||'#888'),borderWidth:2,borderColor:'transparent'}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{font:{size:11},boxWidth:10,padding:8}}}}});
    if(charts.saldo) charts.saldo.destroy();
    charts.saldo=new Chart(document.getElementById('chartSaldo'),{type:'line',data:{labels:meses,datasets:[{label:'Saldo',data:saldoAcum,borderColor:'#378ADD',backgroundColor:'rgba(55,138,221,0.08)',fill:true,tension:0.4,pointRadius:4,pointBackgroundColor:'#378ADD'}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{font:{size:11},color:'#888'},grid:{display:false}},y:{ticks:{callback:v=>'R$'+Math.round(v/1000)+'k',font:{size:11},color:'#888'},grid:{color:'rgba(128,128,128,0.1)'}}}}});
  }

  function renderTabela(tipo) {
    const f=filtradas().filter(c=>c.tipo===tipo);
    const countId=tipo==='pagar'?'countPagar':'countReceber', tableId=tipo==='pagar'?'tabelaPagar':'tabelaReceber';
    const labelAcao=tipo==='pagar'?'Marcar Pago':'Marcar Recebido';
    document.getElementById(countId).textContent=f.length+' registro(s)';
    if(!f.length){ document.getElementById(tableId).innerHTML=`<tr><td colspan="6" class="empty">Nenhum lançamento encontrado.</td></tr>`; return; }
    let html=`<thead><tr><th>Descrição</th><th>Categoria</th><th>Vencimento</th><th>Valor</th><th>Status</th><th>Ações</th></tr></thead><tbody>`;
    f.forEach(c=>{
      const b=c.status==='Pago'?'badge-pago':c.status==='Vencido'?'badge-vencido':'badge-pendente';
      html+=`<tr><td style="font-weight:500">${c.desc}</td><td style="color:var(--text-secondary)">${c.cat}</td><td style="color:var(--text-secondary)">${fmtData(c.venc)}</td><td style="font-weight:600;font-variant-numeric:tabular-nums">${fmt(c.valor)}</td><td><span class="badge ${b}">${c.status}</span></td><td style="display:flex;gap:6px;flex-wrap:wrap;">${c.status!=='Pago'?`<button class="btn btn-sm" onclick="marcarPago('${c.id}')">${labelAcao}</button>`:''}<button class="btn btn-sm" onclick="editarConta('${c.id}')">Editar</button><button class="btn btn-sm btn-danger" onclick="confirmarExclusao('${c.id}')">Excluir</button></td></tr>`;
    });
    document.getElementById(tableId).innerHTML=html+'</tbody>';
  }

  async function marcarPago(id) {
    try{ showLoader(true); await window._db.atualizarConta(id,{status:'Pago'}); showToast('Marcado como pago!'); }
    catch(e){ showToast('Erro: '+e.message,true); } finally{ showLoader(false); }
  }

  async function confirmarExclusao(id) {
    if(!confirm('Excluir este lançamento do Firebase?')) return;
    try{ showLoader(true); await window._db.excluirConta(id); showToast('Lançamento excluído.'); }
    catch(e){ showToast('Erro: '+e.message,true); } finally{ showLoader(false); }
  }

  function editarConta(id) {
    const c=window._contas.find(x=>x.id===id); if(!c) return;
    document.getElementById('modalTitulo').textContent='Editar Conta';
    document.getElementById('fId').value=c.id; document.getElementById('fTipo').value=c.tipo;
    document.getElementById('fDesc').value=c.desc; document.getElementById('fCat').value=c.cat;
    document.getElementById('fValor').value=c.valor; document.getElementById('fVenc').value=c.venc;
    document.getElementById('fStatus').value=c.status;
    document.getElementById('modal').classList.add('open');
  }

  function abrirModal() {
    document.getElementById('modalTitulo').textContent='Nova Conta';
    ['fId','fDesc','fValor'].forEach(id=>document.getElementById(id).value='');
    document.getElementById('fVenc').value=new Date().toISOString().split('T')[0];
    document.getElementById('fStatus').value='Pendente';
    document.getElementById('modal').classList.add('open');
    setTimeout(()=>document.getElementById('fDesc').focus(),100);
  }

  function fecharModal() { document.getElementById('modal').classList.remove('open'); }

  async function salvarConta() {
    const id=document.getElementById('fId').value, tipo=document.getElementById('fTipo').value;
    const desc=document.getElementById('fDesc').value.trim(), cat=document.getElementById('fCat').value;
    const valor=parseFloat(document.getElementById('fValor').value)||0, venc=document.getElementById('fVenc').value;
    const status=document.getElementById('fStatus').value;
    if(!desc){ showToast('Informe a descrição.',true); return; }
    if(valor<=0){ showToast('Informe um valor válido.',true); return; }
    if(!venc){ showToast('Informe a data de vencimento.',true); return; }
    const btn=document.getElementById('btnSalvar');
    btn.disabled=true; btn.textContent='Salvando...';
    try{
      showLoader(true);
      if(id){ await window._db.atualizarConta(id,{tipo,desc,cat,valor,venc,status}); showToast('Conta atualizada!'); }
      else  { await window._db.adicionarConta({tipo,desc,cat,valor,venc,status}); showToast('Conta cadastrada!'); }
      fecharModal();
    } catch(e){ showToast('Erro ao salvar: '+e.message,true); }
    finally{ showLoader(false); btn.disabled=false; btn.textContent='Salvar'; }
  }

  document.getElementById('modal').addEventListener('click',e=>{ if(e.target===document.getElementById('modal')) fecharModal(); });
  document.addEventListener('keydown',e=>{ if(e.key==='Escape') fecharModal(); });
</script>
</body>
</html>
