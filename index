    .filters { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; padding: 1rem 1.25rem; background: var(--bg-primary); border-radius: var(--radius-lg); border: 0.5px solid var(--border); margin-bottom: 1.25rem; box-shadow: var(--shadow); }
