    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 1.25rem; }
    .chart-card { background: var(--bg-primary); border-radius: var(--radius-lg); border: 0.5px solid var(--border); padding: 1.25rem; box-shadow: var(--shadow); }
    .chart-title { font-size: 13px; font-weight: 500; color: var(--text-secondary); margin-bottom: 14px; }
