  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>

  <script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
    import {
      getFirestore, collection, addDoc, getDocs,
      updateDoc, deleteDoc, doc, query, orderBy
    } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

    const firebaseConfig = {
      apiKey:            "AIzaSyDosWSBVz1TzofIlSas3rjcQgvnlse8ReM",
      authDomain:        "financeiro-8c5b9.firebaseapp.com",
      projectId:         "financeiro-8c5b9",
      storageBucket:     "financeiro-8c5b9.firebasestorage.app",
      messagingSenderId: "927705396545",
      appId:             "1:927705396545:web:3908eec97b36ff2b5a9dc0",
      measurementId:     "G-SXYH8H4HY5"
    };

    const app = initializeApp(firebaseConfig);
    const db  = getFirestore(app);
    const col = collection(db, "contas");

    async function carregarContas() {
      try {
        showLoader(true);
        const snap = await getDocs(query(col, orderBy("venc")));
        window._contas = snap.docs.map(d => ({ id: d.id, ...d.data() }));
        renderAll();
      } catch (e) {
        showToast("Erro ao carregar: " + e.message, true);
      } finally {
        showLoader(false);
      }
    }

    async function adicionarConta(dados) {
      const ref = await addDoc(col, dados);
      window._contas.push({ id: ref.id, ...dados });
      renderAll();
    }

    async function atualizarConta(id, dados) {
      await updateDoc(doc(db, "contas", id), dados);
      const idx = window._contas.findIndex(c => c.id === id);
      if (idx !== -1) window._contas[idx] = { ...window._contas[idx], ...dados };
      renderAll();
    }

    async function excluirConta(id) {
      await deleteDoc(doc(db, "contas", id));
      window._contas = window._contas.filter(c => c.id !== id);
      renderAll();
    }

    window._db = { adicionarConta, atualizarConta, excluirConta, carregarContas };
    document.addEventListener("DOMContentLoaded", carregarContas);
  </script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
