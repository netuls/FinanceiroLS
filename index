    .modal-footer { display: flex; gap: 8px; justify-content: flex-end; margin-top: 1rem; }

    .toast { position: fixed; bottom: 1.5rem; right: 1.5rem; padding: 10px 16px; border-radius: var(--radius-md); font-size: 13px; font-weight: 500; z-index: 300; opacity: 0; transform: translateY(8px); transition: all 0.2s; pointer-events: none; background: #1a1a1a; color: #fff; }
